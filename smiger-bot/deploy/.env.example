# ============================================================
#  Smiger AI 智能客服 — 环境变量配置
#  复制此文件为 .env 并填入真实值
#  cp .env.example .env
# ============================================================

# ---------- LLM (大语言模型) ----------
LLM_API_KEY=your-llm-api-key-here
LLM_BASE_URL=https://www.sophnet.com/api/open-apis/v1
LLM_MODEL=DeepSeek-V3.2

# ---------- Embedding (向量嵌入) ----------
EMBEDDING_URL=https://www.sophnet.com/api/open-apis/projects/YOUR_PROJECT_ID/easyllms/embeddings
EMBEDDING_EASYLLM_ID=your-easyllm-id-here
EMBEDDING_DIMENSIONS=1024

# ---------- PostgreSQL ----------
POSTGRES_DB=smiger_bot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ---------- Redis ----------
# (默认无密码，如需认证请自行配置)

# ---------- 端口映射 (可选，默认值如下) ----------
# DB_PORT=5432
# REDIS_PORT=6379
# BACKEND_PORT=8000
# FRONTEND_PORT=3000

# ---------- 管理后台 ----------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password
SECRET_KEY=change-this-to-a-random-secret-in-production
TELEGRAM_ENABLED=false
TELEGRAM_MODE=webhook
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_BASE_URL=
# TELEGRAM_BOT_ACCOUNTS=[{"name":"Tele1","enabled":true,"bot_token":"123:ABC","admin_chat_id":"123456","webhook_secret":""}]
TELEGRAM_BOT_ACCOUNTS=
TELEGRAM_ACTIVE_ACCOUNT=
