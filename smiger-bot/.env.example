# TELEGRAM_BOT_ACCOUNTS=[{"name":"Tele1","enabled":true,"bot_token":"123:ABC","admin_chat_id":"123456","webhook_secret":""},{"name":"Tele2","enabled":true,"bot_token":"456:DEF","admin_chat_id":"789012","webhook_secret":""}]
TELEGRAM_BOT_ACCOUNTS=
